{
  "name": "hugo-dental-theme",
  "version": "1.0.0",
  "description": "A modern Hugo theme for DentalStudio website",
  "license": "MIT",
  "scripts": {
    "start": "hugo server -D -M -w --logLevel warn --navigateToChanged",
    "build": "tailwindcss -i assets/css/main.css -o static/css/main.css --minify && hugo --minify --gc",
    "lint": "prettier . --check",
    "lint:fix": "prettier . -w"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.10",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.6.2",
    "prettier-plugin-go-template": "^0.0.15",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "prettier-plugin-toml": "^2.0.5"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.10",
    "tailwindcss": "^4.1.10"
  }
}
